# Application
NODE_ENV=development
PORT=3001

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database
# For local PostgreSQL:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/silentsiren
# For Neon (recommended for production):
DATABASE_URL=postgresql://username:password@ep-xxx-xxx.region.aws.neon.tech/silentsiren?sslmode=require
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=silentsiren

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# Twilio (for SMS alerts)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# Security
JWT_SECRET=your_jwt_secret_here_min_32_chars
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here_min_32_chars
ENCRYPTION_KEY=your_encryption_key_here_min_32_chars

# Firebase Cloud Messaging (Backend)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour-Private-Key-Here\n-----END PRIVATE KEY-----\n"

# Redis (for caching and rate limiting)
REDIS_URL=redis://localhost:6379

# Monitoring
LOG_LEVEL=info
SENTRY_DSN=

# Railway (production)
RAILWAY_ENVIRONMENT=production
